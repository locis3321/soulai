# SoulAI Backend Environment Configuration

# Server
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://soulai:soulai_password@localhost:5432/soulai_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Services - MiniMax-M3
MINIMAX_API_URL=https://api.office.demo.healthan.com.cn:7443/v1
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL_NAME=MiniMax-M3

# Payment - Alipay
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_NOTIFY_URL=http://localhost:4000/api/payments/callback/alipay
ALIPAY_RETURN_URL=http://localhost:3000/payment/success

# Payment - WeChat Pay
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=http://localhost:4000/api/payments/callback/wechat

# Logging
LOG_LEVEL=debug
